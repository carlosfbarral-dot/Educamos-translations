# Example .env configuration for Educamos Translations

# Database Configuration
DATABASE_URL=your_database_url_here

# Application Settings
APP_NAME=Educamos
APP_ENV=production
APP_DEBUG=false

# API Keys
API_KEY=your_api_key_here

# Export Paths
EXPORT_PATH=/path/to/export

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# UI Preferences
UI_THEME=default
UI_LANGUAGE=en